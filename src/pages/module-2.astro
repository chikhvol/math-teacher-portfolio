---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";

const items = [
  {
    title: "GeoGebra-активності",
    body: "Інтерактивні аплети для дослідження математичних понять: функції, геометричні перетворення, ймовірність. Розділ буде наповнено власними розробками та посиланнями на готові ресурси.",
    tag: "GeoGebra",
  },
  {
    title: "Графіки функцій",
    body: "Динамічні графіки лінійних, квадратичних, тригонометричних та інших функцій із можливістю змінювати параметри й одразу бачити результат.",
    tag: "Аналіз",
  },
  {
    title: "Динамічна геометрія",
    body: "Побудови, у яких учні можуть переміщувати об’єкти й самостійно відкривати закономірності — від властивостей трикутників до теорем планіметрії.",
    tag: "Геометрія",
  },
  {
    title: "Інтерактивні математичні моделі",
    body: "Моделі реальних процесів (рух, зростання, ймовірності), які допомагають побачити математику як мову опису довколишнього світу.",
    tag: "Моделювання",
  },
];
---
<BaseLayout title="Модуль 2. Візуалізація та динамічне моделювання">
  <header class="mb-10">
    <p class="text-sm uppercase tracking-wider text-primary font-semibold">Модуль 2</p>
    <h1 class="text-3xl md:text-4xl font-bold text-base-content mt-1">
      Візуалізація та динамічне моделювання
    </h1>
    <p class="text-secondary mt-3 leading-relaxed max-w-3xl">
      У цьому модулі зібрано матеріали, присвячені візуалізації математичних
      понять і динамічному моделюванню: GeoGebra-активності, графіки функцій,
      побудови з динамічної геометрії, інтерактивні моделі та практичні
      розробки для профільної школи.
    </p>
  </header>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-base-content mb-5">Практичні роботи</h2>
    <div class="grid md:grid-cols-2 gap-5">
      <Card
        title="Міні-проєкт"
        body="Цифровий урок для 11 класу: показникова функція як модель складних відсотків та інфляції з використанням кейс-методу та Desmos."
        tag="Практичне заняття 6–7"
        href="/module-2/mini-project"
      />
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-base-content mb-5">Напрями роботи</h2>
    <div class="grid md:grid-cols-2 gap-5">
      {items.map((i) => <Card title={i.title} body={i.body} tag={i.tag} />)}
    </div>
  </section>

  <section>
    <h2 class="text-2xl font-semibold text-base-content mb-3">
      Візуалізація концепції наукового дослідження
    </h2>
    <p class="text-secondary leading-relaxed max-w-3xl mb-5">
      Документ створено на основі магістерської роботи на тему
      «Розв’язування задач фінансового змісту у профільній школі». У ньому
      подано візуалізований скелет дослідження: ключові поняття, структуру
      теоретичних засад, алгоритм розв’язування задач фінансового змісту,
      взаємозв’язок компонентів методичної системи та SWOT-аналіз дослідження.
    </p>

    <div class="w-full rounded-lg overflow-hidden border border-base-300 bg-base-200">
      <iframe
        src="https://drive.google.com/file/d/1jqDzidTugjcs7O0-NCow75CDZNhnQp3L/preview"
        title="Візуалізація концепції наукового дослідження"
        class="w-full h-[480px] md:h-[700px]"
        allow="autoplay"
        loading="lazy"
      ></iframe>
    </div>

    <div class="mt-4">
      <a
        href="https://drive.google.com/file/d/1jqDzidTugjcs7O0-NCow75CDZNhnQp3L/view?usp=sharing"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary"
      >
        Відкрити документ у Google Drive
      </a>
    </div>
  </section>

</BaseLayout>

