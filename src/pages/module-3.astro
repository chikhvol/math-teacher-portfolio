---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";

const items = [
  {
    title: "ШІ для підготовки уроків",
    body: "Як використовувати ШІ-помічників для генерації плану уроку, добору задач різного рівня складності та створення диференційованих завдань з математики.",
    tag: "Планування",
  },
  {
    title: "Приклади промптів для математики",
    body: "Колекція практичних промптів для типових педагогічних задач: пояснення теми, перевірка розв’язань, підбір контекстних прикладів, створення тестів.",
    tag: "Промпти",
  },
  {
    title: "ШІ для оцінювання та зворотного зв’язку",
    body: "Як ШІ може допомогти формувати персоналізований зворотний зв’язок, аналізувати типові помилки учнів і пришвидшувати рутинні етапи оцінювання.",
    tag: "Оцінювання",
  },
  {
    title: "Відповідальне використання ШІ в освіті",
    body: "Етичні аспекти, академічна доброчесність, конфіденційність даних і критичне ставлення до результатів роботи ШІ — і для вчителя, і для учнів.",
    tag: "Етика",
  },
];

const practicalWork = {
  title: "Практична робота 9–10",
  body: "Критичний аналіз та адаптація математичного контенту, згенерованого ШІ, на темі показникової функції, фінансової грамотності та графічної інтерпретації.",
  tag: "Нова підсторінка",
  href: "/module-3/ai-content-analysis",
};
---
<BaseLayout title="Модуль 3. ШІ в освіті">
  <header class="mb-12 rounded-3xl border border-base-300 bg-gradient-to-br from-purple-50 via-base-100 to-blue-50 p-6 shadow-sm md:p-9">
    <div class="mb-5 flex flex-wrap gap-3">
      <span class="badge badge-primary badge-outline px-3 py-3">Модуль 3</span>
      <span class="badge badge-outline px-3 py-3">ШІ в освіті</span>
      <span class="badge badge-outline px-3 py-3">Відповідальне використання</span>
    </div>
    <h1 class="max-w-4xl text-3xl font-bold leading-tight text-base-content md:text-5xl">
      ШІ в освіті
    </h1>
    <p class="mt-5 max-w-3xl text-lg leading-relaxed text-secondary">
      Модуль присвячено можливостям і викликам використання штучного інтелекту в
      освіті, зокрема у викладанні математики. Тут поступово буде зібрано
      приклади, рефлексії та методичні рекомендації щодо відповідального
      застосування ШІ в роботі вчителя.
    </p>
  </header>

  <section class="mb-10" aria-labelledby="practice-link">
    <div class="rounded-2xl border border-blue-100 bg-gradient-to-br from-blue-50 via-base-100 to-teal-50 p-5 shadow-sm md:p-6">
      <div class="mb-4 max-w-3xl">
        <div class="badge badge-outline badge-primary mb-3">Практичні матеріали</div>
        <h2 id="practice-link" class="text-2xl font-semibold text-base-content">Практична робота № 9–10</h2>
        <p class="mt-2 leading-relaxed text-secondary">
          Окрема сторінка з 5 ШІ-згенерованими завданнями для подальшого критичного аналізу,
          методичного редагування та адаптації до навчання математики в 11 класі.
        </p>
      </div>
      <Card title={practicalWork.title} body={practicalWork.body} tag={practicalWork.tag} href={practicalWork.href} />
    </div>
  </section>

  <section aria-labelledby="module-directions">
    <div class="mb-5 max-w-3xl">
      <div class="badge badge-outline badge-primary mb-3">Матеріали модуля</div>
      <h2 id="module-directions" class="text-2xl font-semibold text-base-content">Напрями досліджень</h2>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {items.map((i) => <Card title={i.title} body={i.body} tag={i.tag} />)}
    </div>
  </section>

  <section class="mt-10">
    <div class="rounded-2xl border border-purple-100 bg-purple-50/60 p-5 shadow-sm md:p-6">
      <div class="badge badge-outline badge-primary mb-3">Розділ у розробці</div>
      <p class="max-w-3xl leading-relaxed text-secondary">
        🤖 Розділ у розробці. У майбутньому тут з’являться конкретні приклади
        промптів, кейси з уроків та рефлексії щодо використання ШІ в навчанні математики.
      </p>
    </div>
  </section>
</BaseLayout>

