---
import BaseLayout from "../../layouts/BaseLayout.astro";

const infoItems = [
  {
    label: "Практичне заняття",
    value:
      "Практичне заняття 6–7. Використання педагогічних технологій та інновацій в математиці у старшій школі",
  },
  {
    label: "Тема магістерської роботи",
    value: "Розв’язування задач фінансового змісту у профільній школі",
  },
  {
    label: "Тема цифрового уроку",
    value: "Показникова функція як модель складних відсотків та інфляції",
  },
  { label: "Клас", value: "11 клас" },
  { label: "Тема з КТП", value: "Показникова та логарифмічна функції" },
  { label: "Педагогічна технологія", value: "Кейс-метод" },
  { label: "Цифровий інструмент", value: "Desmos" },
];

const learningOutcomes = [
  "пояснювати зміст показникової функції у фінансовому контексті;",
  "записувати модель складних відсотків;",
  "будувати графік функції виду S(t) = S₀ · (1 + r)^t;",
  "використовувати Desmos для дослідження параметрів показникової функції;",
  "порівнювати депозитне зростання та інфляційне зростання цін;",
  "аналізувати значення функцій у конкретні моменти часу;",
  "інтерпретувати математичний результат у життєвій фінансовій ситуації;",
  "робити висновок про вигідність або ризики фінансового рішення.",
];

const swotItems = [
  {
    letter: "S",
    title: "Сильні сторони",
    items: [
      "наочна візуалізація показникового зростання;",
      "можливість одночасно бачити графік депозиту та графік інфляційного зростання цін;",
      "інтерактивні слайдери для зміни ставки депозиту, рівня інфляції та початкової суми;",
      "швидке дослідження впливу часу й відсоткової ставки;",
      "доступність через браузер.",
    ],
  },
  {
    letter: "W",
    title: "Слабкі сторони",
    items: [
      "ризик поверхневого сприйняття матеріалу без змістового аналізу;",
      "можлива перевантаженість великою кількістю параметрів;",
      "потреба у попередньому поясненні параметрів S₀, r, i, t;",
      "не всі учні однаково впевнено працюють із цифровими інструментами.",
    ],
  },
  {
    letter: "O",
    title: "Можливості",
    items: [
      "використання для дистанційного та змішаного навчання;",
      "підготовка до НМТ через графічне розуміння функцій;",
      "створення міні-досліджень про депозити, інфляцію, кредити та фінансові сценарії;",
      "поєднання з Google Sheets для табличного аналізу значень.",
    ],
  },
  {
    letter: "T",
    title: "Загрози",
    items: [
      "ризик механічного підбору відповіді без розуміння математичної моделі;",
      "можливість копіювання готового графіка без пояснення;",
      "технічні проблеми з інтернетом або пристроями;",
      "ризик зосередження лише на графіку без фінансової інтерпретації результату.",
    ],
  },
];

const swotStyles = {
  S: "border-t-blue-300 bg-blue-50/60",
  W: "border-t-amber-300 bg-amber-50/60",
  O: "border-t-emerald-300 bg-emerald-50/60",
  T: "border-t-purple-300 bg-purple-50/60",
};

const hintStyles = [
  "border-blue-200 bg-blue-50/70",
  "border-teal-200 bg-teal-50/70",
  "border-purple-200 bg-purple-50/70",
];

const desmosScenarioUrl = "https://www.desmos.com/calculator/yoy5rif8au";
const desmosEmbedUrl = `${desmosScenarioUrl}?embed`;

const lessonSteps = [
  {
    title: "Етап 1. Мотивація",
    text: "Учень має 10 000 грн. Він може покласти гроші на депозит під 10% річних зі складним нарахуванням. Водночас ціни щороку зростають у середньому на 7%. Потрібно з’ясувати, чи справді гроші на депозиті зберігають свою купівельну спроможність.",
  },
  {
    title: "Етап 2. Проблемне питання",
    text: "Що зростає швидше: сума депозиту чи ціни через інфляцію?",
  },
  {
    title: "Етап 3. Математичні моделі",
    text: "D(t) = 10000 · 1,10^t; P(t) = 10000 · 1,07^t",
  },
  {
    title: "Етап 4. Робота в Desmos",
    text: "Учні вводять моделі в Desmos, досліджують графіки та змінюють параметри за допомогою слайдерів.",
  },
  {
    title: "Етап 5. Аналіз графіків",
    text: "Учні порівнюють значення функцій через 1, 3, 5 і 10 років.",
  },
  {
    title: "Етап 6. Фінансова інтерпретація",
    text: "Учні формулюють висновок, чи зберігає депозит купівельну спроможність грошей і як зміниться результат, якщо інфляція становитиме 12%.",
  },
  {
    title: "Етап 7. Узагальнення",
    text: "Учні пояснюють, чому показникова функція є зручною моделлю для опису фінансових процесів.",
  },
];

const valuesTable = [
  ["1 рік", "11 000 грн", "10 700 грн", "Депозит зростає швидше"],
  ["3 роки", "13 310 грн", "12 250,43 грн", "Депозит випереджає інфляцію"],
  ["5 років", "16 105,10 грн", "14 025,52 грн", "Різниця збільшується"],
  ["10 років", "25 937,42 грн", "19 671,51 грн", "Депозит суттєво випереджає інфляцію"],
];

const studentProduct = [
  "побудований графік у Desmos;",
  "таблиця значень для 1, 3, 5 і 10 років;",
  "короткий письмовий висновок;",
  "відповідь на проблемне питання;",
  "пояснення фінансового змісту отриманих результатів.",
];

const criteria = [
  ["Правильність побудови математичних моделей депозиту та інфляції", "3"],
  ["Коректність побудови графіків у Desmos", "2"],
  ["Правильність обчислень і заповнення таблиці значень", "2"],
  ["Фінансова інтерпретація результатів", "3"],
  ["Якість висновку та аргументації", "2"],
  ["Разом", "12"],
];

const hints = [
  {
    title: "Підказка 1 — мінімальна",
    text: "Подумай, яка формула описує ситуацію, коли сума щороку збільшується на один і той самий відсоток. Чи буде така залежність лінійною, чи показниковою?",
  },
  {
    title: "Підказка 2 — середня",
    text: "Для складних відсотків використовують формулу S(t) = S₀ · (1 + r)^t, де S₀ — початкова сума, r — відсоткова ставка у десятковому вигляді, t — кількість років. Наприклад, 10% потрібно записати як 0,10.",
  },
  {
    title: "Підказка 3 — детальна",
    text: "Запиши модель депозиту так: D(t) = 10000 · 1,10^t. Модель інфляції: P(t) = 10000 · 1,07^t. У Desmos введи D(x) = 10000 * 1.10^x і P(x) = 10000 * 1.07^x. Порівняй значення при x = 1, 3, 5, 10.",
  },
];

const comparisonRows = [
  ["Учні виконують обчислення переважно вручну.", "Учні швидко будують графічну модель процесу."],
  ["Важче побачити довгострокову динаміку зростання.", "Графік наочно показує зміну величин у часі."],
  ["Складніше порівнювати кілька сценаріїв.", "Можна одночасно порівнювати депозит, інфляцію та інші варіанти."],
  ["Більше часу витрачається на рутинні розрахунки.", "Більше часу залишається на аналіз, обговорення й висновки."],
  ["Учні можуть сприймати формулу формально.", "Учні бачать, як зміна параметрів впливає на фінансовий результат."],
];

const manualTasks = [
  "створити графік у Desmos;",
  "скопіювати посилання на Desmos-активність;",
  "за потреби отримати iframe-код Desmos;",
  "зробити скриншот графіка;",
  "замінити заглушку на сторінці реальним посиланням;",
  "вставити iframe або скриншот графіка;",
  "перевірити адаптивність сторінки;",
  "опублікувати сайт;",
  "подати посилання на підсторінку “Міні-проєкт” у Google Classroom.",
];
---

<BaseLayout title="Міні-проєкт: Показникова функція як модель складних відсотків та інфляції">
  <header class="mb-12">
    <a href="/module-2" class="btn btn-sm btn-ghost mb-5">← До модуля 2</a>
    <div class="rounded-3xl border border-base-300 bg-gradient-to-br from-blue-50 via-base-100 to-teal-50 p-6 shadow-sm md:p-9">
      <div class="mb-5 flex flex-wrap items-center gap-3">
        <span class="badge badge-primary badge-outline px-3 py-3">Практичне заняття 6–7</span>
        <span class="badge badge-outline px-3 py-3">11 клас</span>
        <span class="badge badge-outline px-3 py-3">Кейс-метод + Desmos</span>
      </div>
      <h1 class="max-w-4xl text-3xl font-bold leading-tight text-base-content md:text-5xl">
        Міні-проєкт: Показникова функція як модель складних відсотків та інфляції
      </h1>
      <p class="mt-5 max-w-3xl text-lg leading-relaxed text-secondary">
        Цифровий урок з алгебри для 11 класу з використанням кейс-методу та Desmos
      </p>
      <div class="mt-6 grid gap-3 text-sm text-secondary sm:grid-cols-3">
        <div class="rounded-2xl border border-base-300 bg-white/70 p-4">
          <span class="font-semibold text-base-content">Фокус</span>
          <p class="mt-1">фінансові задачі та показникове зростання</p>
        </div>
        <div class="rounded-2xl border border-base-300 bg-white/70 p-4">
          <span class="font-semibold text-base-content">Формат</span>
          <p class="mt-1">дослідницький кейс із графічною моделлю</p>
        </div>
        <div class="rounded-2xl border border-base-300 bg-white/70 p-4">
          <span class="font-semibold text-base-content">Результат</span>
          <p class="mt-1">обґрунтований фінансовий висновок</p>
        </div>
      </div>
    </div>
  </header>

  <div class="space-y-12">
    <section aria-labelledby="general-info">
      <div class="mb-5 max-w-3xl">
        <h2 id="general-info" class="text-2xl font-semibold text-base-content">Загальна інформація</h2>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {infoItems.filter((item) => item.label !== "Практичне заняття").map((item) => (
          <div class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-wide text-primary">{item.label}</p>
            <p class="mt-2 leading-relaxed text-base-content">{item.value}</p>
          </div>
        ))}
      </div>
    </section>

    <section aria-labelledby="project-logic">
      <div class="grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-blue-100 bg-blue-50/70 p-5">
          <p class="text-sm font-semibold text-primary">Тема</p>
          <p class="mt-2 text-secondary">показникова функція в реальних фінансових процесах</p>
        </div>
        <div class="rounded-2xl border border-teal-100 bg-teal-50/70 p-5">
          <p class="text-sm font-semibold text-primary">Мета</p>
          <p class="mt-2 text-secondary">дослідити депозит, інфляцію та купівельну спроможність</p>
        </div>
        <div class="rounded-2xl border border-emerald-100 bg-emerald-50/70 p-5">
          <p class="text-sm font-semibold text-primary">Інструмент</p>
          <p class="mt-2 text-secondary">графічне моделювання фінансових сценаріїв у Desmos</p>
        </div>
      </div>
    </section>

    <section aria-labelledby="relevance">
      <article class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm md:p-7">
        <h2 id="relevance" class="text-2xl font-semibold text-base-content">Актуальність теми</h2>
        <div class="mt-4 max-w-3xl space-y-4 text-secondary leading-relaxed">
          <p>
            Тема показникової функції має важливе значення для формування математичної та фінансової грамотності учнів старшої школи. У повсякденному житті старшокласники поступово стикаються з фінансовими поняттями: заощадження, депозит, кредит, інфляція, купівельна спроможність грошей, відсоткова ставка. Для правильного розуміння таких процесів недостатньо лише вміти виконувати арифметичні дії з відсотками. Учні мають усвідомити, що багато фінансових процесів розвиваються не лінійно, а за показниковим законом.
          </p>
          <p>
            Показникова функція дає змогу пояснити, як змінюється сума депозиту за умови складних відсотків, як зростають ціни внаслідок інфляції та чому час є важливим чинником у фінансових розрахунках. Саме тому ця тема органічно пов’язана з магістерською роботою «Розв’язування задач фінансового змісту у профільній школі», оскільки дозволяє розглядати математичні поняття через практично значущі фінансові ситуації.
          </p>
        </div>
      </article>
    </section>

    <section aria-labelledby="goal-results">
      <div class="grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
        <article class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm md:p-6">
            <h2 id="goal-results" class="text-2xl font-semibold text-base-content">Мета цифрового уроку</h2>
            <p class="mt-4 max-w-2xl text-secondary leading-relaxed">
              Сформувати в учнів уміння застосовувати показникову функцію для моделювання фінансових процесів, аналізувати вплив відсоткової ставки та часу на зміну капіталу, порівнювати фінансові сценарії за допомогою графіків у Desmos і робити обґрунтовані висновки щодо збереження купівельної спроможності грошей.
            </p>
        </article>

        <article class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm md:p-6">
          <h2 class="text-2xl font-semibold text-base-content">Очікувані результати навчання</h2>
          <div class="mt-4 grid gap-3">
            {learningOutcomes.map((item) => (
              <div class="flex gap-3 rounded-xl border border-base-300 bg-base-200/60 p-3 text-secondary">
                <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">✓</span>
                <p class="leading-relaxed">{item}</p>
              </div>
            ))}
          </div>
        </article>
      </div>
    </section>

    <section aria-labelledby="method-tool">
      <div class="grid gap-5 lg:grid-cols-[1.05fr_0.95fr]">
        <article class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm md:p-7">
          <h2 id="method-tool" class="text-2xl font-semibold text-base-content">Обґрунтування вибору кейс-методу</h2>
          <div class="mt-4 max-w-3xl space-y-4 text-secondary leading-relaxed">
            <p>
              Для цього цифрового уроку обрано кейс-метод. Його використання є доцільним, оскільки учні працюють не лише з абстрактною формулою, а з конкретною фінансовою ситуацією, наближеною до реального життя.
            </p>
            <p>
              Кейс-метод дозволяє поставити перед учнями проблемне питання: «Чи справді депозит допомагає зберегти купівельну спроможність грошей, якщо ціни також зростають?»
            </p>
            <p>
              Перевага кейс-методу полягає в тому, що учні мають не просто виконати обчислення, а пройти повний шлях дослідження: проаналізувати фінансову ситуацію, виділити відомі та невідомі величини, побудувати математичну модель, дослідити графіки, порівняти результати та зробити практичний висновок.
            </p>
          </div>
        </article>

        <article class="rounded-2xl border border-teal-100 bg-teal-50/60 p-5 shadow-sm md:p-7">
          <p class="text-sm font-semibold uppercase tracking-wide text-primary">Педагогічна логіка</p>
          <h3 class="mt-2 text-xl font-semibold text-base-content">Кейс → модель → графік → висновок</h3>
          <p class="mt-4 text-secondary leading-relaxed">
            Така послідовність допомагає учням перейти від життєвої ситуації до математичної моделі та фінансової інтерпретації результату.
          </p>
        </article>
      </div>
    </section>

    <section aria-labelledby="desmos-activity">
      <article class="rounded-2xl border border-teal-200 bg-gradient-to-br from-teal-50 via-base-100 to-blue-50 p-5 shadow-sm md:p-7">
        <div class="mb-5 max-w-3xl">
          <div class="badge badge-outline badge-primary mb-3">Цифровий інструмент</div>
          <h2 id="desmos-activity" class="text-2xl font-semibold text-base-content">Desmos-активність</h2>
          <div class="mt-4 space-y-4 text-secondary leading-relaxed">
            <p>
              Для реалізації цифрового уроку обрано Desmos, оскільки цей інструмент зручний для побудови й дослідження графіків функцій. У темі показникової функції Desmos допомагає зробити абстрактну математичну модель наочною та зрозумілою.
            </p>
            <p>
              Desmos дає змогу швидко будувати графіки показникових функцій, порівнювати кілька фінансових сценаріїв, використовувати параметри-слайдери, змінювати початкову суму, відсоткову ставку та рівень інфляції, бачити вплив параметрів на форму графіка, зменшити кількість рутинних обчислень і зосередити увагу учнів на аналізі та інтерпретації результатів.
            </p>
          </div>
        </div>

        <div class="mb-4 flex flex-col gap-3 rounded-2xl border border-base-300 bg-white/80 p-4 text-secondary md:flex-row md:items-center md:justify-between">
          <div>
            <span class="font-semibold text-base-content">Посилання на Desmos-сценарій:</span>
            <p class="mt-1 break-all text-sm">{desmosScenarioUrl}</p>
          </div>
          <a
            href={desmosScenarioUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-sm btn-primary shrink-0"
          >
            Відкрити в Desmos
          </a>
        </div>

        <div class="h-[420px] w-full overflow-hidden rounded-2xl border border-base-300 bg-white/70 shadow-sm md:h-[650px]">
          <iframe
            src={desmosEmbedUrl}
            title="Desmos-сценарій: показникова функція як модель складних відсотків та інфляції"
            class="h-full w-full"
            loading="lazy"
          ></iframe>
        </div>
      </article>
    </section>

    <section aria-labelledby="swot">
      <h2 id="swot" class="text-2xl font-semibold text-base-content mb-5">SWOT-аналіз Desmos</h2>
      <div class="grid gap-5 md:grid-cols-2">
        {swotItems.map((block) => (
          <article class={`rounded-2xl border border-base-300 border-t-4 p-5 shadow-sm ${swotStyles[block.letter]}`}>
            <div class="mb-4 flex items-center gap-3">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white/80 font-bold text-primary">
                {block.letter}
              </span>
              <h3 class="text-xl font-semibold text-base-content">{block.title}</h3>
            </div>
            <ul class="list-disc pl-5 space-y-2 text-secondary leading-relaxed">
              {block.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section aria-labelledby="lesson-plan">
      <h2 id="lesson-plan" class="text-2xl font-semibold text-base-content mb-5">Сценарне планування цифрового уроку</h2>
      <div class="relative space-y-5 before:absolute before:left-5 before:top-2 before:hidden before:h-full before:w-px before:bg-base-300 md:before:block">
        {lessonSteps.map((step, index) => (
          <article class="relative md:pl-14">
            <div class="absolute left-0 top-5 hidden h-10 w-10 items-center justify-center rounded-full border border-base-300 bg-base-100 text-sm font-semibold text-primary shadow-sm md:flex">
              {index + 1}
            </div>
            <div class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm md:p-6">
              <div class="mb-3 flex items-center gap-3 md:hidden">
                <span class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10 text-sm font-semibold text-primary">{index + 1}</span>
                <span class="text-sm font-semibold text-primary">Етап уроку</span>
              </div>
              <h3 class="text-xl font-semibold text-base-content">{step.title}</h3>
              <p class="mt-2 text-secondary leading-relaxed">{step.text}</p>
              {step.title === "Етап 3. Математичні моделі" && (
                <div class="mt-4 grid gap-4 md:grid-cols-2">
                  <div class="rounded-2xl border border-blue-100 bg-blue-50/70 p-5 text-center font-mono text-lg text-base-content">
                    D(t) = 10000 · 1,10^t
                  </div>
                  <div class="rounded-2xl border border-teal-100 bg-teal-50/70 p-5 text-center font-mono text-lg text-base-content">
                    P(t) = 10000 · 1,07^t
                  </div>
                </div>
              )}
              {step.title === "Етап 4. Робота в Desmos" && (
                <div class="mt-4 grid gap-4 md:grid-cols-2">
                  <pre class="overflow-x-auto rounded-2xl border border-base-300 bg-base-200 p-4 text-sm"><code>{`D(x) = 10000 * 1.10^x
P(x) = 10000 * 1.07^x`}</code></pre>
                  <pre class="overflow-x-auto rounded-2xl border border-base-300 bg-base-200 p-4 text-sm"><code>{`S_0 = 10000
r = 0.10
i = 0.07

D(x) = S_0 * (1 + r)^x
P(x) = S_0 * (1 + i)^x`}</code></pre>
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section aria-labelledby="values-table">
      <h2 id="values-table" class="text-2xl font-semibold text-base-content mb-5">Таблиця значень</h2>
      <div class="overflow-x-auto rounded-lg border border-base-300 bg-base-100 shadow-sm">
        <table class="table table-zebra min-w-[720px]">
          <thead>
            <tr>
              <th>Час</th>
              <th>D(t) = 10000 · 1,10^t</th>
              <th>P(t) = 10000 · 1,07^t</th>
              <th>Висновок</th>
            </tr>
          </thead>
          <tbody>
            {valuesTable.map((row) => (
              <tr>
                {row.map((cell) => <td>{cell}</td>)}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section aria-labelledby="student-task">
      <h2 id="student-task" class="text-2xl font-semibold text-base-content mb-3">Навчальне завдання для учнів</h2>
      <article class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm md:p-6">
        <div class="max-w-3xl space-y-4 text-secondary leading-relaxed">
          <p>
            За допомогою Desmos побудуйте графіки двох функцій:<br />
            D(t) = 10000 · 1,10^t — модель зростання депозиту;<br />
            P(t) = 10000 · 1,07^t — модель зростання цін через інфляцію.
          </p>
          <p>
            Визначте значення обох функцій через 1, 3, 5 і 10 років. Порівняйте результати. Зробіть висновок: чи є депозит вигідним з погляду збереження купівельної спроможності грошей?
          </p>
          <p>Дослідіть, як зміниться результат, якщо інфляція становитиме 12%.</p>
        </div>
      </article>
    </section>

    <section aria-labelledby="student-product">
      <div class="grid gap-5 lg:grid-cols-[0.85fr_1.15fr]">
        <article class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm md:p-6">
          <h2 id="student-product" class="text-2xl font-semibold text-base-content">Очікуваний продукт діяльності учня</h2>
          <div class="mt-4 space-y-3">
            {studentProduct.map((item) => (
              <div class="flex gap-3 rounded-xl border border-base-300 bg-base-200/50 p-3 text-secondary">
                <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">✓</span>
                <p class="leading-relaxed">{item}</p>
              </div>
            ))}
          </div>
        </article>

        <article class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm md:p-6">
          <h2 class="text-2xl font-semibold text-base-content">ШІ-асистент: три рівні підказок</h2>
          <div class="mt-4 space-y-4">
            {hints.map((hint, index) => (
              <div class={`rounded-2xl border p-4 ${hintStyles[index]}`}>
                <p class="text-sm font-semibold uppercase tracking-wide text-primary">Рівень {index + 1}</p>
                <h3 class="mt-1 font-semibold text-base-content">{hint.title}</h3>
                <p class="text-secondary leading-relaxed mt-2">{hint.text}</p>
              </div>
            ))}
          </div>
        </article>
      </div>
    </section>

    <section aria-labelledby="criteria">
      <h2 id="criteria" class="text-2xl font-semibold text-base-content mb-5">Критерії оцінювання</h2>
      <div class="overflow-x-auto rounded-lg border border-base-300 bg-base-100 shadow-sm">
        <table class="table table-zebra min-w-[640px]">
          <thead>
            <tr>
              <th>Критерій</th>
              <th>Максимальна кількість балів</th>
            </tr>
          </thead>
          <tbody>
            {criteria.map((row) => (
              <tr class={row[0] === "Разом" ? "font-semibold" : ""}>
                <td>{row[0]}</td>
                <td>{row[1]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section aria-labelledby="mistakes-effectiveness">
      <div class="grid gap-5 lg:grid-cols-[1.05fr_0.95fr]">
        <article class="rounded-2xl border border-amber-200 bg-amber-50/70 p-5 shadow-sm md:p-6">
          <h2 id="mistakes-effectiveness" class="text-2xl font-semibold text-base-content">Типова помилкова логіка</h2>
          <p class="mt-2 text-secondary leading-relaxed">
            Мета цього блоку — допомогти учням побачити різницю між простими та складними відсотками і не втратити фінансовий зміст задачі.
          </p>
          <div class="mt-4 grid gap-3 md:grid-cols-2">
            <div class="rounded-2xl border border-amber-200 bg-white/70 p-4">
              <p class="text-sm font-semibold text-base-content">Неправильна логіка</p>
              <p class="mt-2 font-mono text-base-content">D(t) = 10000 + 1000t</p>
              <p class="mt-2 text-sm text-secondary">Це модель простих відсотків.</p>
            </div>
            <div class="rounded-2xl border border-emerald-200 bg-white/70 p-4">
              <p class="text-sm font-semibold text-base-content">Правильна модель</p>
              <p class="mt-2 font-mono text-base-content">D(t) = 10000 · 1,10^t</p>
              <p class="mt-2 text-sm text-secondary">Відсотки нараховуються і на вже нараховані відсотки.</p>
            </div>
          </div>
          <div class="mt-4 space-y-4 text-secondary leading-relaxed">
            <p>
              Типова помилка учня — заміна складних відсотків простими. Наприклад, учень може записати модель депозиту як D(t) = 10000 + 1000t. Така формула описує прості відсотки, коли щороку додається однакова сума. Для складних відсотків правильна модель має вигляд D(t) = 10000 · 1,10^t, оскільки відсотки нараховуються не лише на початкову суму, а й на вже нараховані відсотки.
            </p>
            <p>
              Ще одна помилка — ігнорування інфляції. Учень може зробити висновок, що депозит завжди вигідний, бо сума грошей зростає. Але потрібно порівнювати не лише номінальну суму, а й зміну купівельної спроможності грошей.
            </p>
          </div>
        </article>

        <article class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm md:p-6">
          <h2 class="text-2xl font-semibold text-base-content">Прогноз ефективності Desmos</h2>
          <p class="mt-4 text-secondary leading-relaxed">
            Реальний учень зможе скористатися Desmos для виконання цього завдання, якщо він розуміє зміст параметрів S₀, r, i, t і має базові навички побудови графіків. Desmos допомагає побачити різницю між лінійним і показниковим зростанням, а також порівняти кілька фінансових сценаріїв. Водночас учитель має супроводжувати роботу учнів запитаннями, щоб вони не обмежилися лише побудовою графіків, а пояснили їхній математичний і фінансовий зміст.
          </p>
        </article>
      </div>
    </section>

    <section aria-labelledby="comparison">
      <h2 id="comparison" class="text-2xl font-semibold text-base-content mb-5">Порівняння “без технології” та “з технологією”</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <div class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm">
          <h3 class="text-xl font-semibold text-base-content">Без технології</h3>
          <div class="mt-4 space-y-3">
            {comparisonRows.map((row) => (
              <div class="rounded-xl border border-base-300 bg-base-200/50 p-3 text-secondary leading-relaxed">
                {row[0]}
              </div>
            ))}
          </div>
        </div>
        <div class="rounded-2xl border border-teal-200 bg-teal-50/60 p-5 shadow-sm">
          <h3 class="text-xl font-semibold text-base-content">З Desmos</h3>
          <div class="mt-4 space-y-3">
            {comparisonRows.map((row) => (
              <div class="rounded-xl border border-teal-100 bg-white/70 p-3 text-secondary leading-relaxed">
                {row[1]}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="conclusion">
      <article class="rounded-2xl border border-blue-100 bg-gradient-to-br from-blue-50 via-base-100 to-emerald-50 p-5 shadow-sm md:p-7">
        <div class="badge badge-outline badge-primary mb-3">Підсумок міні-проєкту</div>
        <h2 id="conclusion" class="text-2xl font-semibold text-base-content">Висновок</h2>
        <div class="mt-4 max-w-3xl space-y-4 text-secondary leading-relaxed">
          <p>
            Використання кейс-методу та цифрового інструменту Desmos дає змогу поєднати тему показникової функції з реальними фінансовими ситуаціями. Такий цифровий урок допомагає учням зрозуміти, що математичні функції є не лише теоретичним об’єктом, а й засобом моделювання процесів, які безпосередньо пов’язані з життям людини.
          </p>
          <p>
            На прикладі депозиту та інфляції учні вчаться аналізувати фінансову ситуацію, будувати математичну модель, досліджувати графіки, порівнювати результати та формулювати обґрунтований висновок. Це сприяє формуванню математичної компетентності, фінансової грамотності, критичного мислення та здатності приймати відповідальні рішення.
          </p>
          <p>
            Міні-проєкт безпосередньо пов’язаний із магістерською роботою «Розв’язування задач фінансового змісту у профільній школі», оскільки демонструє один із можливих способів реалізації фінансово орієнтованих задач у курсі математики старшої школи.
          </p>
        </div>
      </article>
    </section>
  </div>
</BaseLayout>


