---
import BaseLayout from "../layouts/BaseLayout.astro";
import CertificateCard from "../components/CertificateCard.astro";

const featuredCertificates = [
    {
        title: "Кіберграм",
        description:
            "Сертифікат, пов’язаний із цифровою грамотністю, кібербезпекою та відповідальним використанням онлайн-середовища в освітній діяльності.",
        reflection:
            "Цей матеріал важливий для організації безпечної цифрової роботи учнів під час використання інтерактивних сервісів, онлайн-моделей і спільних навчальних ресурсів.",
        certificateUrl: "/certificates/кіберграм.pdf",
    },
    {
        title: "Підвищення кваліфікації: інформатична освітня галузь",
        description:
            "Сертифікат про проходження навчання у червні 2025 року за програмою підвищення кваліфікації для вчителів, які забезпечують упровадження Державного стандарту базової середньої освіти у 2025/2026 навчальному році.",
        reflection:
            "Курс допомагає краще поєднувати математичну освіту з цифровими інструментами, алгоритмічним мисленням, моделюванням та практичним застосуванням ІТ у навчанні.",
        certificateUrl: "/certificates/Чіх%20В.І._інформат_06.2025.pdf",
    },
    {
        title: "Підвищення кваліфікації: природнича освітня галузь / фізика",
        description:
            "Сертифікат Івано-Франківського обласного інституту післядипломної педагогічної освіти про навчання за програмою підвищення кваліфікації обсягом 24 години. У програмі зазначено модулі: безпечне освітнє середовище, методичні особливості організації освітнього процесу та інноваційні підходи у викладанні й оцінюванні навчальних досягнень.",
        reflection:
            "Матеріали курсу корисні для міжпредметного підходу: математичні моделі, графіки, вимірювання та аналіз даних природничих процесів можуть стати основою для візуалізації й динамічного моделювання на уроках.",
        certificateUrl: "/certificates/Чіх%20Вол_курси_червень_2025.jpg",
    },
];

const testingCertificates = [
    {
        title: "Практичний тест: Інформатика — 10 клас",
        description:
            "Результат проходження тесту «Приклади питань / 10 клас» з предмету Інформатика на платформі Naurok: 45,75 із 50 балів (91,5%).",
        reflection:
            "Тестування підтвердило впевнений рівень знань базових тем інформатики 10 класу та визначило напрями для подальшого опрацювання.",
        certificateUrl: "/images/testing/inf-10.png",
    },
    {
        title: "Практичний тест: Інформатика — 11 клас",
        description:
            "Результат проходження тесту «Приклади питань / 11 клас» з предмету Інформатика на платформі Naurok: 49,2 із 50 балів (98,4%).",
        reflection:
            "Високий результат засвідчив глибоке розуміння тем інформатики 11 класу, пов’язаних із цифровими технологіями та алгоритмікою.",
        certificateUrl: "/images/testing/inf-11.png",
    },
    {
        title: "Практичний тест: Математика — 11 клас",
        description:
            "Результат проходження тесту «Приклади питань / 11 клас» з предмету Математика на платформі Naurok: 50 із 50 балів (100%).",
        reflection:
            "Максимальний результат відображає впевнене знання ключових тем математики 11 класу, які безпосередньо стосуються профільного навчання.",
        certificateUrl: "/images/testing/math-11.png",
    },
    {
        title: "Практичний тест: створення сайту в Google Сайтах",
        description:
            "Результат практичного тесту зі створення освітнього сайту в сервісі Google Сайти на платформі Naurok: 13/15 балів (86,67%).",
        reflection:
            "Це завдання допомогло відпрацювати структурування навчального контенту, візуальне оформлення сторінок і базову навігацію для цифрового освітнього середовища.",
        certificateUrl: "/images/testing/naurok.png",
    },
];

const certificates = [
    {
        title: "Тест «Цифрограм для вчителів»",
        description:
            "Національний тест на визначення рівня цифрової грамотності педагогічних працівників відповідно до Рамки цифрової компетентності.",
        reflection:
            "Тестування показало мої сильні сторони та зони росту в роботі з цифровими інструментами; це стало поштовхом до вивчення нових сервісів для уроків математики.",
        certificateUrl: "/certificates/digigram.pdf",
    },
    {
        title: "Онлайн-курс «Безпечний простір»",
        description:
            "Курс розкриває питання безпеки в освітньому середовищі, профілактики булінгу та створення атмосфери, у якій учні можуть почуватися захищено й комфортно.",
        reflection:
            "Цей курс нагадав мені, що урок починається не лише з теми чи завдання, а з атмосфери в класі. Якщо учень почувається в безпеці, йому легше запитувати, помилятися, думати вголос і поступово рухатися до розуміння математики.",
        certificateUrl: "/certificates/safe-space.png",
    },
    {
        title: "Онлайн-курс «Академічна доброчесність»",
        description:
            "Курс формує розуміння принципів академічної доброчесності, правил коректного цитування та відповідального ставлення до знань.",
        reflection:
            "Я зрозумів, що академічна доброчесність починається з учителя: власним прикладом ми формуємо у школярів культуру чесного навчання та поваги до чужої праці.",
        certificateUrl: "/certificates/academic-integrity.pdf",
    },
];
---
<BaseLayout title="Модуль 1. Цифрова дидактика">
    <header class="mb-12 rounded-3xl border border-base-300 bg-gradient-to-br from-blue-50 via-base-100 to-teal-50 p-6 shadow-sm md:p-9">
        <div class="mb-5 flex flex-wrap gap-3">
            <span class="badge badge-primary badge-outline px-3 py-3">Модуль 1</span>
            <span class="badge badge-outline px-3 py-3">Цифрова дидактика</span>
        </div>
        <h1 class="max-w-4xl text-3xl font-bold leading-tight text-base-content md:text-5xl">
            Цифрова дидактика
        </h1>
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-secondary">
            Цей розділ присвячений моєму знайомству з цифровою дидактикою та інструментами, які допомагають зробити
            навчання математики більш безпечним, сучасним і доступним для учнів.

            У межах модуля я опрацював матеріали, пов’язані з безпечним освітнім середовищем, академічною доброчесністю,
            цифровою компетентністю вчителя та роллю цифрових технологій у математичній освіті.
        </p>
    </header>

    <!-- A. Сертифікати -->
    <section class="mb-14">
        <div class="mb-5 max-w-3xl">
            <div class="badge badge-outline badge-primary mb-3">Професійне навчання</div>
            <h2 class="text-2xl font-semibold text-base-content">Сертифікати курсів</h2>
        </div>
        <div class="grid gap-5 md:grid-cols-3">
            {featuredCertificates.map((c) => (
                    <CertificateCard
                            title={c.title}
                            description={c.description}
                            reflection={c.reflection}
                            certificateUrl={c.certificateUrl}
                    />
            ))}
        </div>
    </section>

    <section class="mb-14">
        <div class="mb-5 max-w-3xl">
            <div class="badge badge-outline mb-3">Інші сертифікати модуля</div>
            <h2 class="text-2xl font-semibold text-base-content">Курси та тестування</h2>
        </div>
        <div class="grid gap-5 md:grid-cols-2">
            {certificates.map((c) => (
                <CertificateCard
                    title={c.title}
                    description={c.description}
                    reflection={c.reflection}
                    certificateUrl={c.certificateUrl}
                />
            ))}
        </div>
    </section>

    <section class="mb-14">
        <div class="mb-5 max-w-3xl">
            <div class="badge badge-outline mb-3">Тестування</div>
            <h2 class="text-2xl font-semibold text-base-content">Результати практичних тестів</h2>
            <p class="mt-3 leading-relaxed text-secondary">
                Підсумкові скріншоти проходження практичних тестів на платформі Naurok з інформатики, математики та зі створення сайту в Google Сайтах.
            </p>
        </div>
        <div class="grid gap-5 md:grid-cols-2">
            {testingCertificates.map((c) => (
                <CertificateCard
                    title={c.title}
                    description={c.description}
                    reflection={c.reflection}
                    certificateUrl={c.certificateUrl}
                />
            ))}
        </div>
    </section>

    <!-- B. Есе -->
    <section class="mb-14">
        <article class="rounded-2xl border border-blue-100 bg-gradient-to-br from-blue-50 via-base-100 to-emerald-50 p-5 shadow-sm md:p-7">
            <h2 class="text-2xl font-semibold text-base-content">Цифрові технології в математичній освіті</h2>
            <div class="prose-page mt-4 max-w-3xl space-y-4">
                <p class="text-secondary leading-relaxed">
                    Цифрові технології поступово стають невід’ємною частиною уроку математики.
                    Вони не замінюють учителя, але дають йому нові інструменти, щоб зробити
                    складні поняття зрозумілішими, а навчання — більш персоналізованим.
                </p>
                <p class="text-secondary leading-relaxed">
                    Сучасний учень живе у світі екранів і миттєвої інформації. Якщо ми хочемо,
                    щоб математика залишалася для нього значущою, ми маємо говорити з ним його
                    мовою: через інтерактивні моделі, динамічні графіки, навчальні відео та
                    грамотно дібрані онлайн-завдання.
                </p>
                <p class="text-secondary leading-relaxed">
                    Водночас цифрові технології ставлять перед педагогом нові виклики:
                    відповідальне використання даних, академічна доброчесність, безпека в
                    інтернеті, критичне ставлення до інформації. Тому цифрова дидактика — це
                    не лише про інструменти, а й про педагогічну культуру в цифровому світі.
                </p>
            </div>
        </article>
    </section>

    <!-- C. Хмаринка слів -->
    <section class="mb-14">
        <div class="mb-5 max-w-3xl">
        <h2 class="text-2xl font-semibold text-base-content">Цифрова компетентність учителя математики</h2>
        <p class="mt-3 leading-relaxed text-secondary">
            Окремо я спробував візуально представити ключові поняття, які асоціюються з цифровою компетентністю вчителя
            математики. Такий формат допомагає швидко побачити, які навички й підходи є важливими для сучасного
            педагога.
        </p>
        </div>
        <figure class="overflow-hidden rounded-2xl border border-base-300 bg-base-200 shadow-sm">
            <img
                    src="/images/word-cloud.jpeg"
                    alt="Хмаринка слів: цифрова компетентність вчителя математики"
                    class="w-full object-contain"
            />
        </figure>
    </section>

    <!-- D. Рефлексія -->
    <section>
        <div class="rounded-2xl border border-blue-100 bg-gradient-to-br from-blue-50 via-base-100 to-emerald-50 p-5 shadow-sm md:p-7">
            <div class="badge badge-outline badge-primary mb-3">Рефлексія</div>
            <h2 class="text-2xl font-semibold text-base-content">Що дав мені цей модуль</h2>
            <div class="mt-4 max-w-3xl space-y-4">
                <p class="text-secondary leading-relaxed">
                    Робота над цим модулем допомогла мені краще впорядкувати власні навчальні матеріали, сертифікати та
                    професійні напрацювання. Створення цифрового портфоліо стало для мене не просто виконанням
                    практичного завдання, а способом поєднати математику, цифрові технології та власний педагогічний
                    досвід у зручному форматі.
                </p>
                <p class="text-secondary leading-relaxed">
                    Також цей процес дав змогу по-новому подивитися на роль учителя в цифровому освітньому середовищі. Я
                    зрозумів, що такий сайт може стати корисним інструментом не лише для представлення власної роботи, а
                    й для подальшого професійного розвитку.
                </p>
                <p class="text-secondary leading-relaxed">
                    У майбутньому портфоліо стане живим простором, у якому я систематично
                    збиратиму методичні розробки, рефлексії та зворотний зв’язок від учнів і
                    колег.
                </p>
            </div>
        </div>
    </section>
</BaseLayout>
