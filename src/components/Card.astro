---
const { title, body, href, tag } = Astro.props;
---
<div class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm transition-shadow hover:shadow-md">
  <div class="flex h-full flex-col">
    {tag && <div class="badge badge-outline badge-primary mb-3">{tag}</div>}
    <h3 class="text-xl font-semibold leading-snug text-base-content">{title}</h3>
    <p class="mt-3 text-sm leading-relaxed text-secondary">{body}</p>
    {href && (
      <div class="mt-5 flex justify-end">
        <a href={href} class="btn btn-sm btn-primary">Детальніше</a>
      </div>
    )}
  </div>
</div>

