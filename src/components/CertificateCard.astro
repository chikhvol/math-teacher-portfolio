---
// CertificateCard — простий компонент для відображення сертифіката курсу.
// Plain JavaScript у frontmatter, без TypeScript-інтерфейсів.
const { title, description, reflection, certificateUrl } = Astro.props;
---
<article class="h-full rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm transition-shadow hover:shadow-md">
  <div class="flex h-full flex-col">
    <div class="flex items-start gap-3">
      <div class="mt-1 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold leading-snug text-base-content">{title}</h3>
    </div>

    {description && (
      <p class="text-sm text-secondary leading-relaxed mt-2">
        <span class="font-semibold text-base-content">Про курс: </span>{description}
      </p>
    )}

    {reflection && (
      <p class="text-sm text-secondary leading-relaxed">
        <span class="font-semibold text-base-content">Що я взяв із курсу: </span>{reflection}
      </p>
    )}

    <div class="mt-auto flex justify-end pt-4">
      <a
        href={certificateUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-sm btn-primary"
      >
        Переглянути сертифікат
      </a>
    </div>
  </div>
</article>

