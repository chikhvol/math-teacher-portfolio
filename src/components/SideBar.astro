---
import { SITE } from "../config.js";
import SideBarMenu from "./SideBarMenu.astro";
---
<div class="drawer-side z-40">
  <label for="my-drawer-3" aria-label="Закрити меню" class="drawer-overlay"></label>
  <aside class="bg-base-100 w-80 min-h-full border-r border-base-300 flex flex-col">
    <div class="px-6 py-6 border-b border-base-300">
      <a href="/" class="block">
        <h1 class="text-xl font-bold leading-tight text-base-content">
          {SITE.title}
        </h1>
      </a>
    </div>
    <nav class="flex-1 py-4">
      <SideBarMenu />
    </nav>
    <div class="px-6 py-4 border-t border-base-300 text-xs text-secondary">
      Університетський практикум · Цифрове портфоліо
    </div>
  </aside>
</div>

